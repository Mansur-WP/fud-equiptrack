# Django environment variables
# Copy this file to .env and update values for your environment.

# DEVELOPMENT / LOCAL
# Set to "true" to enable development mode.
DJANGO_DEBUG=true

# SAFE DEVELOPMENT ONLY
# For development you may keep the default dev secret.
# For production (DJANGO_DEBUG=false), provide a real secret via env var.
DJANGO_SECRET_KEY=

# Comma-separated list of hosts allowed by Django.
# Examples: localhost,127.0.0.1,0.0.0.0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

